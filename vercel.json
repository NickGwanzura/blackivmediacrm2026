{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/health", "destination": "/api/server" },
    { "source": "/health/(.*)", "destination": "/api/server" },
    { "source": "/sync", "destination": "/api/server" },
    { "source": "/sync/(.*)", "destination": "/api/server" },
    { "source": "/delete/(.*)", "destination": "/api/server" },
    { "source": "/force-push", "destination": "/api/server" },
    { "source": "/((?!api/|assets/).*)", "destination": "/index.html" }
  ]
}
