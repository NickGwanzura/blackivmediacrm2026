# Local development environment variables
# Rename this to .env.local or .env to use locally.

# Frontend (Vite)
VITE_API_KEY=your_google_generative_ai_key_here

# API server (server/index.js) — Neon connection
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Signing secret for session + reset-token JWTs. REQUIRED in production —
# if unset, the server falls back to an ephemeral random secret that
# invalidates every session on each restart. Use at least 32 random bytes.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Environment marker. When set to "production" the session cookie is marked
# Secure, and the initial-admin seeding refuses to use the dev fallback email.
NODE_ENV=development

# Email of the initial Admin account seeded on first boot when the `users`
# table is empty. REQUIRED in production. In dev, falls back to
# admin@blackivymedia.local with a loud warning. The password is generated
# randomly at seed time and printed to stdout once — grab it from the logs.
ADMIN_EMAIL=admin@blackivymedia.local

# Optional: explicit absolute URL used to build links in auth emails
# (e.g. password reset links). Defaults to the incoming request's origin.
# APP_URL=https://crm.example.com

# Optional CORS restriction. When unset, the server reflects the request
# Origin so the cookie-based auth flow works in local dev. In production set
# this to the exact public origin so the browser only accepts credentialed
# requests from that host.
# ALLOWED_ORIGIN=https://crm.example.com

# Legacy bearer-token gate. Auth middleware based on JWT cookies replaces
# this for /auth/*, /sync, /delete, /email, /force-push. You can still set
# API_SECRET if you want an extra layer — but it's no longer how the UI
# authenticates.
# API_SECRET=change-me

# Resend transactional email — required for the Send Email buttons on
# invoices, contracts, and statements, AND for the auth flows (password
# reset, approval notice, invite email). Key at https://resend.com/api-keys
RESEND_API_KEY=re_xxx_replace_me
# Verified sender. Until you verify a domain, Resend only lets you send
# from onboarding@resend.dev to the address that owns the API key.
EMAIL_FROM=Black Ivy Media <onboarding@resend.dev>
